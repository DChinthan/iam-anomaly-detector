# Copy to .env and fill in what you need. Every var below has a working
# default (mock mode, SQLite, rule-based GenAI) — nothing here is required
# to run `python main.py pipeline` or `streamlit run dashboard/app.py`.

# ── Cloud provider routing (main.py ingest/score/stream) ────────────────────
# aws (default) | gcp | mock — "mock" is an explicit alias for the default
# aws + AWS_MOCK=true path (zero real AWS calls either way).
CLOUD_PROVIDER=aws

# ── AWS backend (aws/cloudwatch_client.py, aws/dynamodb_store.py) ──────────
AWS_MOCK=true
# AWS_REGIONS=us-east-1,us-west-2,eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# DYNAMODB_TABLE=iam-anomaly-results

# ── GCP backend (gcp/cloud_logging_client.py, gcp/firestore_store.py) ──────
GCP_MOCK=true
# GCP_PROJECT=my-gcp-project
# GCP_REGIONS=us-central1,us-east1
# FIRESTORE_COLLECTION=iam-anomaly-results

# ── Streaming (streaming/event_stream.py) ───────────────────────────────────
# mock (default) | kafka | pubsub
STREAM_MODE=mock
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=iam-cloudtrail-events
# PUBSUB_TOPIC=iam-cloudtrail-events
# PUBSUB_SUBSCRIPTION=iam-anomaly-scorer-sub
# PUBSUB_EMULATOR_HOST=localhost:8085   # run the local Pub/Sub emulator, see gcp/README.md

# ── Database (data/db.py) ────────────────────────────────────────────────────
# Unset -> local SQLite (data/iam_logs.db), zero setup.
#
# AWS RDS/Aurora Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@rds-endpoint.amazonaws.com:5432/iam_anomaly
#
# GCP Cloud SQL Postgres — standard connection string via the Cloud SQL
# Auth Proxy (`cloud-sql-proxy <instance-connection-name> --port 5432`) or a
# public IP with an authorized network. This needs NO code changes: db.py's
# engine.dialect.name check resolves to "postgresql" identically to RDS.
# DATABASE_URL=postgresql+psycopg2://user:pass@127.0.0.1:5432/iam_anomaly
#
# GCP Cloud SQL via the native Cloud SQL Python Connector (IAM auth, no
# proxy/open port) is NOT plug-and-play like the line above — the connector
# needs a `creator` callable passed to create_engine(), not a plain URL, so
# using it would require a small change to data/db.py's get_engine().
# See: https://github.com/GoogleCloudPlatform/cloud-sql-python-connector

# ── GenAI (genai/insights.py) ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=

# ── Dashboard auth (dashboard/auth.py) ──────────────────────────────────────
# DASHBOARD_USERS=admin:admin123:admin,analyst:analyst123:analyst,viewer:viewer123:viewer
